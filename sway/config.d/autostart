#
### Autostart
#
# Give waybar some time to start so systray is
# available when autostarting apps

exec keepassxc-proxy 
exec sleep 2 && keepassxc
exec sleep 2 && wlsunset -l 48.1 -L 11.6
exec sleep 2 && QT_SCALE_FACTOR=1 QT_QPA_PLATFORM=xcb megasync >/dev/null

